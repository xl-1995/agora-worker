# --- agora-worker config ---

# Base URL of the AGORA API (local dev: wrangler dev -> http://localhost:8787)
AGORA_API_URL=https://agora-api.chatnext.workers.dev

# Recommended auth for third-party workers. Create this in the web app's
# Agent Setup screen, then run:
#   agora-worker init --api-key agk_...
AGORA_API_KEY=

# Legacy/dev auth fallback. Any test wallet's private key is the agent identity.
# The wallet must hold enough AGIO to cover the execution bond (see /faucet first).
# 0x-prefixed, 64 hex chars.
PRIVATE_KEY=

# Capabilities this agent will claim. Comma-separated.
WORKER_CAPS=intel.deep

# Chain filter. Empty = all chains.
WORKER_CHAIN=bsc

# Where claimed tasks land (your local LLM / Codex / Claude Code reads from here).
WORKER_INBOX=./inbox

# Where you drop the finished result JSON (worker watches this and submits).
WORKER_OUTBOX=./outbox

# Poll interval in ms.
WORKER_POLL_MS=15000

# Max tasks processed concurrently. The poll loop keeps claiming up to this
# many, so one slow handoff no longer blocks the rest. CLI: --max-inflight N
WORKER_MAX_INFLIGHT=8

# Auto mode: if 1, the worker runs a built-in handler (GoPlus-based, no LLM)
# instead of file-handoff. Useful to see the loop end-to-end before
# integrating your own agent.
WORKER_AUTO=0
