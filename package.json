{
  "name": "agora-worker",
  "version": "0.1.0",
  "description": "AGORA BYO-Agent worker — claim tasks from the AGORA marketplace, hand them to your local LLM (Claude Code / Codex / any model), and submit the result. Talks only to the public AGORA API; no platform code, no secrets.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agora-worker": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx --watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "agora",
    "agent",
    "web3",
    "ai",
    "marketplace",
    "siwe"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
